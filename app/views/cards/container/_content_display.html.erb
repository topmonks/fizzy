<h1 class="card__title flex align-start gap-half">
  <%= link_to card_html_title(card), edit_card_path(card), class: "card__title-link" %>
</h1>

<% unless card.description.blank? %>
  <div class="card__description lexxy-content" data-controller="syntax-highlight retarget-links">
    <%= card.description %>
  </div>
<% end %>

<% if card.estimate_hours.present? || card.actual_hours.present? %>
  <% actual = card.actual_hours || 0
     estimate = card.estimate_hours || 0
     hours_status = if estimate > 0 && actual > estimate
       "over"
     elsif estimate > 0 && (estimate - actual).to_f / estimate <= 0.25
       "warning"
     else
       "ok"
     end %>
  <div class="card__hours card__hours--display card__hours--<%= hours_status %>">
    <span class="card__hours-item">
      Budget: <strong><%= number_with_precision(actual, strip_insignificant_zeros: true) %> of <%= number_with_precision(estimate, strip_insignificant_zeros: true) %></strong> hours consumed
    </span>
  </div>
<% end %>
