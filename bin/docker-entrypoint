#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${1}" == "./bin/thrust" ] && [ "${2}" == "./bin/rails" ] && [ "${3}" == "server" ]; then
  MIGRATE=1 ./bin/rails db:prepare

  # All databases share one PostgreSQL URL, so db:prepare only migrates the primary DB.
  # Load secondary schemas on first boot if their tables don't exist yet.
  ./bin/rails runner "
    conn = ActiveRecord::Base.connection
    {
      'solid_queue_jobs'     => 'db/queue_schema.rb',
      'solid_cable_messages' => 'db/cable_schema.rb',
      'solid_cache_entries'  => 'db/cache_schema.rb',
    }.each do |table, schema_path|
      unless conn.table_exists?(table)
        puts \"Loading \#{schema_path}...\"
        load Rails.root.join(schema_path)
      end
    end
  "
fi

exec "${@}"
